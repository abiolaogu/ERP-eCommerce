NEXT_PUBLIC_COSMO_URL=http://localhost:3002/graphql
NEXT_PUBLIC_CENTRIFUGO_URL=ws://localhost:8000/connection/websocket
NEXT_PUBLIC_DEFAULT_TENANT=tenant-default
NEXT_PUBLIC_AUTH_POLICY=demo-token-fallback
