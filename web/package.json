{
  "name": "erp-ecommerce-web-package-shim",
  "private": true,
  "version": "0.0.0",
  "description": "Legacy frontend shim forwarding to apps/sovereign-next16",
  "sovereignLegacyShim": true,
  "scripts": {
    "dev": "cd ../apps/sovereign-next16 && npm run --workspaces=false dev",
    "build": "cd ../apps/sovereign-next16 && npm run --workspaces=false build",
    "start": "cd ../apps/sovereign-next16 && npm run --workspaces=false --if-present start",
    "lint": "cd ../apps/sovereign-next16 && npm run --workspaces=false --if-present lint",
    "test": "cd ../apps/sovereign-next16 && npm run --workspaces=false --if-present test",
    "typecheck": "cd ../apps/sovereign-next16 && npm run --workspaces=false --if-present typecheck"
  }
}
